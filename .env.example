# ============================================================
# ALIFA LMS — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Database (PostgreSQL via Neon/Prisma)
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/alifa_lms"

# NextAuth.js Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Session cookie name (optional, default: next-auth.session-token)
# SESSION_NAME="next-auth.session-token"

# Node environment
NODE_ENV="development"

# ============================================================
# SMTP Email (untuk reset password & undangan)
# ============================================================

# Gmail: https://myaccount.google.com/apppasswords
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="yourmail@gmail.com"
# SMTP_PASS="xxxx xxxx xxxx xxxx"  (App Password, bukan password login)
# SMTP_FROM="ALIFA Institute <noreply@alifa.ac.id>"

# Alternatif — Resend (gratis 100/hari): https://resend.com
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT=465
# SMTP_USER="resend"
# SMTP_PASS="re_xxxxxxxx"  (Resend API Key)

# Atau Brevo (gratis 300/hari): https://brevo.com
# SMTP_HOST="smtp-relay.brevo.com"
# SMTP_PORT=587
# SMTP_USER="your@email.com"
# SMTP_PASS="xsmtpsib-xxxxxxxx"

# ============================================================
# Optional — hanya untuk production
# ============================================================

# Custom domain (jika deploy ke production)
# NEXTAUTH_URL="https://lms.alifa.ac.id"
